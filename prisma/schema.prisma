generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Sex {
  MALE
  FEMALE
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum Goal {
  FAT_LOSS
  MUSCLE_GAIN
  MAINTENANCE
  PERFORMANCE
}

enum WorkRoutine {
  CLT_9_TO_5
  HOME_OFFICE
  SHIFT_WORK
  FLEXIBLE
  STUDENT
  OTHER
}

enum DietaryRestriction {
  NONE
  VEGAN
  VEGETARIAN
  LACTOSE_FREE
  GLUTEN_FREE
  LOW_CARB
  KETO
}

enum ExerciseType {
  WEIGHTLIFTING
  RUNNING
  CROSSFIT
  CALISTHENICS
  CYCLING
  SWIMMING
  MARTIAL_ARTS
  HIIT
  WALKING
  OTHER
}

enum IntensityLevel {
  LIGHT
  MODERATE
  INTENSE
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  passwordHash      String
  profile           UserProfile?
  tasteProfile      TasteProfile?
  onboardingAnswers OnboardingAnswer[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("users")
}

model UserProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  age                 Int
  sex                 Sex
  heightCm            Float
  weightKg            Float
  bodyFatPercentage   Float?
  state               String?
  city                String?
  activityLevel       ActivityLevel
  exerciseFrequency   Int
  primaryExerciseType ExerciseType?
  exerciseDurationMin Int?
  exerciseIntensity   IntensityLevel?
  mealsPerDay         Int                @default(3)
  workRoutine         WorkRoutine
  dietaryRestrictions DietaryRestriction @default(NONE)
  weeklyFoodBudget    Float?
  goal                Goal
  tdee                Float?
  targetCalories      Float?
  targetProteinG      Float?
  targetFatG          Float?
  targetCarbsG        Float?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@map("user_profiles")
}

model OnboardingAnswer {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_answers")
}

model TasteProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stapleFoods     String   @default("[]")
  aversions       String   @default("[]")
  sweetPreference Int      @default(3)
  saltyPreference Int      @default(3)
  spicyTolerance  Int      @default(2)
  cookingSkill    Int      @default(3)
  cookingTime     Int?
  favoriteFoods   String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("taste_profiles")
}

model Food {
  id            String   @id @default(cuid())
  name          String
  category      String
  brand         String?
  unit          String   @default("g")
  caloriesKcal  Float
  proteinG      Float
  fatG          Float
  carbsG        Float
  fiberG        Float    @default(0)
  sugarG        Float    @default(0)
  vitaminA_UG   Float    @default(0)
  vitaminC_MG   Float    @default(0)
  vitaminD_UG   Float    @default(0)
  vitaminE_MG   Float    @default(0)
  vitaminK_UG   Float    @default(0)
  vitaminB1_MG  Float    @default(0)
  vitaminB2_MG  Float    @default(0)
  vitaminB3_MG  Float    @default(0)
  vitaminB5_MG  Float    @default(0)
  vitaminB6_MG  Float    @default(0)
  vitaminB9_UG  Float    @default(0)
  vitaminB12_UG Float    @default(0)
  calcium_MG    Float    @default(0)
  iron_MG       Float    @default(0)
  magnesium_MG  Float    @default(0)
  zinc_MG       Float    @default(0)
  potassium_MG  Float    @default(0)
  sodium_MG     Float    @default(0)
  selenium_UG   Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@map("foods")
}
